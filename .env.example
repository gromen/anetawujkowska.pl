# Only used in production builds. Leave empty on localhost — tracking is disabled there regardless.
PUBLIC_GTM_ID=GTM-XXXXXXX

# Absolute site URL — used for canonical links, Open Graph and the OG image.
# Defaults to https://anetawujkowska.pl. Set this to the temporary deploy URL
# (e.g. https://anetawujkowska.gromson101.workers.dev) so link previews work
# before the real domain is live.
PUBLIC_SITE_URL=https://anetawujkowska.pl
