---
<div id="cookie-bar" class="cookie-bar hidden" role="dialog" aria-live="polite" aria-label="Zgoda na pliki cookie">
  <p>
    Używamy plików cookie do analityki (Google Analytics). Bez Twojej zgody
    nie śledzimy ruchu na stronie. Szczegóły w
    <a href="/polityka-prywatnosci">polityce prywatności</a>.
  </p>
  <div class="cookie-actions">
    <button type="button" data-cookie="accept" class="btn primary">Akceptuję</button>
    <button type="button" data-cookie="reject" class="btn ghost">Odrzuć</button>
  </div>
</div>

<script is:inline>
  (function () {
    const KEY = 'cookie-consent';
    const bar = document.getElementById('cookie-bar');
    if (!bar) return;

    let existing = null;
    try { existing = localStorage.getItem(KEY); } catch (e) {}
    if (!existing) bar.classList.remove('hidden');

    function choose(choice) {
      try { localStorage.setItem(KEY, choice); } catch (e) {}
      bar.classList.add('hidden');
      if (choice === 'accept') {
        if (typeof window.gtag === 'function') {
          window.gtag('consent', 'update', {
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted',
            analytics_storage: 'granted',
          });
        }
        if (typeof window.__loadGTM === 'function') window.__loadGTM();
      }
    }

    bar.querySelectorAll('[data-cookie]').forEach((btn) => {
      btn.addEventListener('click', () => choose(btn.getAttribute('data-cookie')));
    });
  })();
</script>
