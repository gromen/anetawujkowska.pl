---
import { site } from '~/lib/site';

const gtmId = site.gtmId;
const enabled = import.meta.env.PROD && !!gtmId;
---

{enabled && (
  <script is:inline define:vars={{ gtmId }}>
    (function () {
      const host = location.hostname;
      if (host === 'localhost' || host === '127.0.0.1' || host.endsWith('.local')) {
        window.__GTM_DISABLED__ = true;
        return;
      }

      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;

      // Consent denied by default — nothing is tracked until the visitor accepts.
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
      });

      // GTM is injected ONLY after consent — never before.
      var loaded = false;
      window.__loadGTM = function () {
        if (loaded || window.__GTM_DISABLED__) return;
        loaded = true;
        window.dataLayer.push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtm.js?id=' + gtmId;
        document.head.appendChild(s);
      };

      // Returning visitor who already accepted — restore consent and load.
      try {
        if (localStorage.getItem('cookie-consent') === 'accept') {
          gtag('consent', 'update', {
            ad_storage: 'granted',
            ad_user_data: 'granted',
            ad_personalization: 'granted',
            analytics_storage: 'granted',
          });
          window.__loadGTM();
        }
      } catch (e) {}
    })();
  </script>
)}
