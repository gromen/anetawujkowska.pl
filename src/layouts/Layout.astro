---
import "@fontsource/geist/300.css";
import "@fontsource/geist/400.css";
import "@fontsource/geist/500.css";
import "@fontsource/geist/600.css";
import "@fontsource/geist/800.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/geist-mono/500.css";
import "@fontsource/space-grotesk/400.css";
import "@fontsource/space-grotesk/500.css";
import "@fontsource/space-grotesk/600.css";
import "@fontsource/space-grotesk/700.css";
import sg600url from "@fontsource/space-grotesk/files/space-grotesk-latin-600-normal.woff2?url";
import CookieBar from "~/components/CookieBar.astro";
import Footer from "~/components/Footer.astro";
import GA4 from "~/components/GA4.astro";
import Nav from "~/components/Nav.astro";
import StickyCall from "~/components/StickyCall.astro";
import { site } from "~/lib/site";
import "~/styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  heroPreloadSrcset?: string;
  heroPreloadSizes?: string;
}

const { title, description = site.description, heroPreloadSrcset, heroPreloadSizes } = Astro.props;
const pageTitle =
  title ?? "Aneta Wujkowska — Ekspert Finansowy · Ostrów Mazowiecka";
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImage = `${site.url}${site.ogImage}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FinancialService",
  name: site.company.legalName,
  image: ogImage,
  url: site.url,
  telephone: site.contact.phone,
  email: site.contact.email,
  priceRange: "Bezpłatnie dla klienta",
  address: {
    "@type": "PostalAddress",
    streetAddress: site.contact.addressLine,
    postalCode: "07-300",
    addressLocality: "Ostrów Mazowiecka",
    addressRegion: "mazowieckie",
    addressCountry: "PL",
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      opens: "09:00",
      closes: "17:00",
    },
  ],
};
---

<!doctype html>
<html lang="pl-PL">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="kredyt hipoteczny Ostrów Mazowiecka, kredyt gotówkowy, konsolidacja, kredyt dla rolników, pośrednik kredytowy, ekspert finansowy, Aneta Wujkowska"
    />
    <meta name="author" content="Aneta Wujkowska" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#0f1b2d" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="anetawujkowska.pl" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:secure_url" content={ogImage} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Aneta Wujkowska — ekspert finansowy"
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="Aneta Wujkowska — ekspert finansowy"
    />

    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />

    <link rel="preload" as="font" type="font/woff2" href={sg600url} crossorigin="anonymous" />
    {heroPreloadSrcset && <link rel="preload" as="image" imagesrcset={heroPreloadSrcset} imagesizes={heroPreloadSizes} fetchpriority="high" />}

    <GA4 />
  </head>
  <body>
    <!-- <Ribbon /> -->
    <Nav />
    <main id="main"><slot /></main>
    <Footer />
    <StickyCall />
    <CookieBar />
  </body>
</html>
